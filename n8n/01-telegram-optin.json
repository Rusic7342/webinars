{
  "name": "itscontentflow — 01 Telegram opt-in + survey",
  "nodes": [
    {
      "parameters": {
        "updates": ["message", "callback_query"],
        "additionalFields": {}
      },
      "id": "tg-trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [200, 460],
      "credentials": { "telegramApi": { "name": "webinar_M_bot" } }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "loose" },
          "conditions": [
            {
              "id": "is-cb",
              "leftValue": "={{ $json.callback_query ? 'yes' : 'no' }}",
              "rightValue": "yes",
              "operator": { "type": "string", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-callback",
      "name": "Is button tap?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [420, 460]
    },
    {
      "parameters": {
        "jsCode": "const msg = $input.first().json.message || {};\nconst text = (msg.text || '').trim();\nconst parts = text.split(/\\s+/);\nconst startParam = parts[0] === '/start' ? (parts[1] || '') : '';\nconst uuidRe = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;\nconst hasLead = uuidRe.test(startParam);\nreturn [{ json: {\n  chat_id: msg.chat && msg.chat.id,\n  first_name: (msg.chat && msg.chat.first_name) || (msg.from && msg.from.first_name) || '',\n  lead_id: hasLead ? startParam : '',\n  has_lead: hasLead\n} }];"
      },
      "id": "parse-start",
      "name": "Parse start",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [640, 620]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "loose" },
          "conditions": [
            {
              "id": "has-lead",
              "leftValue": "={{ $json.has_lead }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-has-lead",
      "name": "Has lead_id?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [860, 620]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://coxzeqtgtokfsrfnzxwn.supabase.co/rest/v1/webinar_leads?id=eq.{{ $json.lead_id }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"tg_chat_id\": {{ $json.chat_id }}, \"tg_connected_at\": \"{{ $now.toISO() }}\" }",
        "options": { "response": { "response": { "responseFormat": "text" } } }
      },
      "id": "link-tg",
      "name": "Link tg_chat_id",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1080, 540],
      "credentials": { "supabaseApi": { "name": "Supabase Beyond Promts (service_role)" } }
    },
    {
      "parameters": {
        "chatId": "={{ $('Parse start').item.json.chat_id }}",
        "text": "=✅ You're connected{{ $('Parse start').item.json.first_name ? ', ' + $('Parse start').item.json.first_name : '' }}! Quick one so I tailor the workshop 👇\n\nWhere are you with AI for content right now?",
        "replyMarkup": "inlineKeyboard",
        "inlineKeyboard": {
          "rows": [
            { "row": { "buttons": [ { "text": "🌱 Just starting", "additionalFields": { "callback_data": "lvl|beginner" } } ] } },
            { "row": { "buttons": [ { "text": "⚙️ Practicing", "additionalFields": { "callback_data": "lvl|practicing" } } ] } },
            { "row": { "buttons": [ { "text": "🚀 Advanced", "additionalFields": { "callback_data": "lvl|pro" } } ] } }
          ]
        },
        "additionalFields": {}
      },
      "id": "send-q1",
      "name": "Send Q1 level",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1300, 540],
      "credentials": { "telegramApi": { "name": "webinar_M_bot" } }
    },
    {
      "parameters": {
        "chatId": "={{ $('Parse start').item.json.chat_id }}",
        "text": "👋 This is the reminders bot for the free live workshop \"Your AI has never met your client.\"\n\nTo get your reminders here, first save your seat on the site — then tap the Telegram button on the confirmation screen:\n👉 https://webinar.itscontentflow.com",
        "additionalFields": {}
      },
      "id": "ask-register",
      "name": "Ask to register",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1080, 720],
      "credentials": { "telegramApi": { "name": "webinar_M_bot" } }
    },
    {
      "parameters": {
        "jsCode": "const cb = $input.first().json.callback_query || {};\nconst data = (cb.data || '');\nconst i = data.indexOf('|');\nconst field = i >= 0 ? data.slice(0, i) : data;\nconst value = i >= 0 ? data.slice(i + 1) : '';\nconst map = { lvl:'level', goal:'goal', apply:'apply', exp:'experience', strg:'struggle', niche:'niche' };\nconst col = map[field] || null;\nlet next;\nif (field==='lvl') next='q_goal';\nelse if (field==='goal') next='q_apply';\nelse if (field==='apply') next='gate';\nelse if (field==='gate') next = (value==='yes') ? 'q_exp' : 'done_no';\nelse if (field==='exp') next='q_strg';\nelse if (field==='strg') next='q_niche';\nelse if (field==='niche') next='done';\nelse next='done';\nreturn [{ json: {\n  chat_id: cb.from && cb.from.id,\n  first_name: (cb.from && cb.from.first_name) || '',\n  field, value, col, hasCol: !!col, next\n} }];"
      },
      "id": "parse-callback",
      "name": "Parse callback",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [640, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "loose" },
          "conditions": [
            {
              "id": "has-col",
              "leftValue": "={{ $json.hasCol }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-has-col",
      "name": "Save this answer?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [860, 300]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://coxzeqtgtokfsrfnzxwn.supabase.co/rest/v1/webinar_leads?tg_chat_id=eq.{{ $json.chat_id }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ {{ JSON.stringify($json.col) }}: {{ JSON.stringify($json.value) }} }",
        "options": { "response": { "response": { "responseFormat": "text" } } }
      },
